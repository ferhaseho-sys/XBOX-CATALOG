# Copiar a .env y rellenar. En Railway se configuran como Variables.

# Supabase: usar el POOLER (puerto 6543), NO la conexion directa (IPv6).
DATABASE_URL=postgresql://postgres.xxxx:TU_PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres

# --- Rendimiento de ingesta (defaults agresivos, pensados para Railway) ---
# Si NO seteas estas vars, el codigo ya usa: WORKERS=24, REQ_RATE=20, BATCH_SIZE=400.
# Local (con proxy TLS) no llega a esa velocidad; el pricing rapido corre en Railway.
# REQ_RATE es el TECHO global req/seg (anti-429), no un freno.
WORKERS=24
REQ_RATE=20
BATCH_SIZE=400
HTTP_TIMEOUT=60
HTTP_POOL=32
