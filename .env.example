# Copiar a .env y rellenar. En Railway se configuran como Variables.

# Supabase: Project Settings > Database > Connection string.
# Para workers de ingesta usar el POOLER (puerto 6543), no la conexion directa.
DATABASE_URL=postgresql://postgres.xxxx:TU_PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres

# Ritmo de la API (req/seg). Subir con cuidado; hay caidas SSL/429 si se abusa.
REQ_RATE=6
# IDs por lote batch (100-200 recomendado; details pesa ~3-7 MB por lote).
BATCH_SIZE=150
# Mercados precificados en paralelo (cada uno abre su propia conexion).
MARKET_WORKERS=4
